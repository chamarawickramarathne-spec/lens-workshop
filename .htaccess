<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect to HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Proxy /api and /uploads to the Node.js backend
  # Note: 3001 is the default port set in your server.js
  RewriteRule ^api/(.*) http://localhost:3001/api/$1 [P,L]
  RewriteRule ^uploads/(.*) http://localhost:3001/uploads/$1 [P,L]

  # Standard React Router handling:
  # Always serve index.html for any route that isn't a physical file
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Increase upload size limits if supported by the host
# php_value upload_max_filesize 64M
# php_value post_max_size 64M
